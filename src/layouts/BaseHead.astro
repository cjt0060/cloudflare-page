---
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  type?: "website" | "article";
  publishedDate?: string;
}

const {
  title,
  description = "Cloud Engineer portfolio — infrastructure, DevOps, and platform engineering.",
  image = "/og-default.png",
  canonicalUrl = Astro.url.href,
  type = "website",
  publishedDate,
} = Astro.props;

const siteTitle = `${title} | Cloud Engineer`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    {publishedDate && <meta property="article:published_time" content={publishedDate} />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Blog RSS Feed" href="/rss.xml" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Your Name",
      "url": canonicalUrl,
      "jobTitle": "Cloud Engineer",
      "description": description,
      "sameAs": [
        "https://github.com/yourusername",
        "https://linkedin.com/in/yourusername"
      ]
    })} />
  </head>
  <body
    class="min-h-screen bg-surface-950 text-surface-100 font-sans antialiased selection:bg-primary-500/30"
  >
    <slot />
  </body>
</html>
