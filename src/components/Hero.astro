---
interface Props {
  title: string;
  subtitle?: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const { title, subtitle, primaryCTA, secondaryCTA } = Astro.props;
---

<section class="section-padding relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-600/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-primary-400/5 rounded-full blur-3xl"></div>
  </div>

  <div class="section-container text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight text-white animate-in">
      <Fragment set:html={title} />
    </h1>

    {subtitle && (
      <p class="mt-6 text-lg sm:text-xl text-surface-400 max-w-2xl mx-auto leading-relaxed animate-in" style="animation-delay: 0.1s">
        {subtitle}
      </p>
    )}

    {(primaryCTA || secondaryCTA) && (
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-in" style="animation-delay: 0.2s">
        {primaryCTA && (
          <a href={primaryCTA.href} class="btn-primary">
            {primaryCTA.label}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        )}
        {secondaryCTA && (
          <a href={secondaryCTA.href} class="btn-secondary">
            {secondaryCTA.label}
          </a>
        )}
      </div>
    )}
  </div>
</section>
