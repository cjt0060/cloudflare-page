---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
---

{totalPages > 1 && (
  <nav class="flex items-center justify-center gap-2 mt-12" aria-label="Pagination">
    {currentPage > 1 && (
      <a
        href={currentPage === 2 ? baseUrl : `${baseUrl}/${currentPage - 1}`}
        class="px-3 py-2 text-sm rounded-lg border border-surface-700 text-surface-400 hover:text-white hover:border-surface-600 transition-colors"
        aria-label="Previous page"
      >
        &larr; Prev
      </a>
    )}

    {pages.map((page) => (
      <a
        href={page === 1 ? baseUrl : `${baseUrl}/${page}`}
        class:list={[
          "px-3 py-2 text-sm rounded-lg transition-colors",
          page === currentPage
            ? "bg-primary-600 text-white"
            : "border border-surface-700 text-surface-400 hover:text-white hover:border-surface-600",
        ]}
        aria-current={page === currentPage ? "page" : undefined}
      >
        {page}
      </a>
    ))}

    {currentPage < totalPages && (
      <a
        href={`${baseUrl}/${currentPage + 1}`}
        class="px-3 py-2 text-sm rounded-lg border border-surface-700 text-surface-400 hover:text-white hover:border-surface-600 transition-colors"
        aria-label="Next page"
      >
        Next &rarr;
      </a>
    )}
  </nav>
)}
