---
interface Props {
  title: string;
  description: string;
  primaryCTA: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const { title, description, primaryCTA, secondaryCTA } = Astro.props;
---

<section class="section-padding border-t border-surface-800/50">
  <div class="section-container text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
      {title}
    </h2>
    <p class="mt-4 text-lg text-surface-400 max-w-xl mx-auto">
      {description}
    </p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={primaryCTA.href} class="btn-primary">{primaryCTA.label}</a>
      {secondaryCTA && (
        <a href={secondaryCTA.href} class="btn-secondary">{secondaryCTA.label}</a>
      )}
    </div>
  </div>
</section>
