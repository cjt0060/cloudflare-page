---
interface TimelineItem {
  title: string;
  company?: string;
  date: string;
  description: string;
  technologies?: string[];
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<div class="relative">
  <div class="absolute left-4 top-0 bottom-0 w-px bg-surface-800"></div>

  <div class="space-y-8">
    {items.map((item, index) => (
      <div class="relative pl-12" style={`animation-delay: ${index * 0.1}s`}>
        <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full bg-primary-500 border-2 border-surface-950"></div>

        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
            <h3 class="text-base font-semibold text-white">{item.title}</h3>
            <span class="text-xs text-surface-500 whitespace-nowrap">{item.date}</span>
          </div>

          {item.company && (
            <p class="text-sm text-primary-400 mb-2">{item.company}</p>
          )}

          <p class="text-sm text-surface-400 leading-relaxed">{item.description}</p>

          {item.technologies && item.technologies.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {item.technologies.map((tech) => (
                <span class="px-2 py-0.5 text-xs rounded bg-surface-800 text-surface-300 border border-surface-700">
                  {tech}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
