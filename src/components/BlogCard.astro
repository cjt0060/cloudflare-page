---
interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  readingTime: string;
  href: string;
  tags?: string[];
}

const { title, description, date, category, readingTime, href, tags } = Astro.props;
---

<article class="card group">
  <div class="flex items-center gap-3 mb-3">
    <span class="px-2.5 py-0.5 text-xs font-medium rounded-full bg-primary-500/10 text-primary-400 border border-primary-500/20">
      {category}
    </span>
    <span class="text-xs text-surface-500">{readingTime}</span>
  </div>

  <h3 class="text-lg font-semibold text-white group-hover:text-primary-400 transition-colors">
    <a href={href} class="hover:underline">{title}</a>
  </h3>

  <p class="mt-2 text-sm text-surface-400 leading-relaxed line-clamp-2">
    {description}
  </p>

  <div class="mt-4 flex items-center justify-between">
    <time datetime={date} class="text-xs text-surface-500">
      {new Date(date).toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
      })}
    </time>

    <a
      href={href}
      class="text-sm text-primary-400 hover:text-primary-300 transition-colors flex items-center gap-1"
    >
      Read more
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</article>
