---
interface Props {
  name: string;
  icon?: string;
}

const { name, icon } = Astro.props;
---

<span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg bg-surface-800/80 text-surface-300 border border-surface-700/50 hover:border-primary-500/30 hover:text-primary-300 transition-colors duration-200">
  {icon && <span class="text-base">{icon}</span>}
  {name}
</span>
