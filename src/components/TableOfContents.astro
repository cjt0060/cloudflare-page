---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <div class="sticky top-24">
    <h4 class="text-xs font-semibold uppercase tracking-wider text-surface-500 mb-3">
      On this page
    </h4>
    <nav aria-label="Table of contents">
      <ul class="space-y-2 text-sm border-l border-surface-800">
        {filteredHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                "block py-0.5 border-l -ml-px transition-colors hover:text-primary-400 hover:border-primary-400",
                heading.depth === 2 ? "pl-4 text-surface-400 border-transparent" : "pl-8 text-surface-500 border-transparent",
              ]}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}
