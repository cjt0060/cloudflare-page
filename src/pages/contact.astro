---
import BaseLayout from "@layouts/BaseLayout.astro";
import SocialIcons from "@components/SocialIcons.astro";
---

<BaseLayout title="Contact" description="Get in touch — let's discuss cloud architecture, collaboration, or opportunities.">
  <section class="section-padding">
    <div class="section-container">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
          <h1 class="text-4xl sm:text-5xl font-bold text-white tracking-tight">Get in Touch</h1>
          <p class="mt-4 text-lg text-surface-400 max-w-2xl">
            Have a question, want to collaborate, or interested in working together? 
            I'd love to hear from you.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <!-- Contact Form -->
          <div class="lg:col-span-2">
            <form
              action="https://formspree.io/f/your-form-id"
              method="POST"
              class="space-y-6"
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-surface-300 mb-2">
                    Name
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    autocomplete="name"
                    class="w-full px-4 py-3 rounded-lg bg-surface-900 border border-surface-700 text-white placeholder-surface-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-colors"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-surface-300 mb-2">
                    Email
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    class="w-full px-4 py-3 rounded-lg bg-surface-900 border border-surface-700 text-white placeholder-surface-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-colors"
                    placeholder="you@example.com"
                  />
                </div>
              </div>

              <div>
                <label for="subject" class="block text-sm font-medium text-surface-300 mb-2">
                  Subject
                </label>
                <input
                  type="text"
                  id="subject"
                  name="subject"
                  required
                  class="w-full px-4 py-3 rounded-lg bg-surface-900 border border-surface-700 text-white placeholder-surface-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-colors"
                  placeholder="What's this about?"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-surface-300 mb-2">
                  Message
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="6"
                  class="w-full px-4 py-3 rounded-lg bg-surface-900 border border-surface-700 text-white placeholder-surface-500 focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-colors resize-y"
                  placeholder="Tell me about your project or question..."
                ></textarea>
              </div>

              <!-- Cloudflare Turnstile placeholder -->
              <div class="cf-turnstile" data-sitekey="your-turnstile-site-key" data-theme="dark"></div>

              <button type="submit" class="btn-primary w-full sm:w-auto">
                Send Message
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </button>
            </form>
          </div>

          <!-- Contact Info Sidebar -->
          <div class="space-y-6">
            <div class="card">
              <h3 class="text-sm font-semibold text-white mb-3">Email</h3>
              <a href="mailto:hello@yourdomain.com" class="text-sm text-primary-400 hover:text-primary-300 transition-colors">
                hello@yourdomain.com
              </a>
            </div>

            <div class="card">
              <h3 class="text-sm font-semibold text-white mb-3">Social</h3>
              <SocialIcons size="md" />
            </div>

            <div class="card">
              <h3 class="text-sm font-semibold text-white mb-3">Response Time</h3>
              <p class="text-sm text-surface-400">
                I typically respond within 24-48 hours. For urgent matters, reach out via LinkedIn.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
