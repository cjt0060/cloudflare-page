---
import BaseLayout from "@layouts/BaseLayout.astro";
import BlogCard from "@components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());

const categories = [...new Set(posts.map((p) => p.data.category))];
---

<BaseLayout title="Blog" description="Articles about cloud engineering, Kubernetes, AWS, Terraform, and platform engineering.">
  <section class="section-padding">
    <div class="section-container">
      <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
          <h1 class="text-4xl sm:text-5xl font-bold text-white tracking-tight">Blog</h1>
          <p class="mt-4 text-lg text-surface-400 max-w-2xl">
            Thoughts on cloud engineering, DevOps practices, and lessons learned building infrastructure at scale.
          </p>
        </div>

        <!-- Categories -->
        <div class="flex flex-wrap gap-2 mb-10">
          <span class="px-3 py-1.5 text-sm rounded-lg bg-primary-500/10 text-primary-400 border border-primary-500/20">
            All ({posts.length})
          </span>
          {categories.map((cat) => (
            <span class="px-3 py-1.5 text-sm rounded-lg text-surface-400 border border-surface-700 hover:border-surface-600 transition-colors cursor-default">
              {cat}
            </span>
          ))}
        </div>

        <!-- Posts Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.publishedDate}
              category={post.data.category}
              readingTime={`${Math.ceil(post.body!.split(/\s+/).length / 200)} min read`}
              href={`/blog/${post.slug}`}
              tags={post.data.tags}
            />
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
