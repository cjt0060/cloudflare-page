---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import ProjectCard from "@components/ProjectCard.astro";
import BlogCard from "@components/BlogCard.astro";
import CertificationCard from "@components/CertificationCard.astro";
import TechBadge from "@components/TechBadge.astro";
import CTA from "@components/CTA.astro";
import { projects } from "@/data/projects";
import { certifications } from "@/data/certifications";
import { getCollection } from "astro:content";

const featuredProjects = projects.filter((p) => p.featured).slice(0, 3);
const featuredCerts = certifications.slice(0, 4);

const blogPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
  .slice(0, 3);

const technologies = [
  { name: "AWS", icon: "☁️" },
  { name: "Kubernetes", icon: "⎈" },
  { name: "Terraform", icon: "🏗️" },
  { name: "Docker", icon: "🐳" },
  { name: "Python", icon: "🐍" },
  { name: "Go", icon: "🔷" },
  { name: "TypeScript", icon: "📘" },
  { name: "Linux", icon: "🐧" },
  { name: "GitOps", icon: "🔄" },
  { name: "Prometheus", icon: "📊" },
  { name: "GCP", icon: "🌐" },
  { name: "Azure", icon: "🔵" },
];
---

<BaseLayout title="Home" description="Cloud Engineer specializing in AWS, Kubernetes, and platform engineering. Building resilient, scalable infrastructure.">
  <!-- Hero -->
  <Hero
    title='Building <span class="gradient-text">Cloud Infrastructure</span> That Scales'
    subtitle="Cloud Engineer specializing in designing, building, and operating production-grade distributed systems. Passionate about platform engineering, DevOps culture, and infrastructure automation."
    primaryCTA={{ label: "View Projects", href: "/projects" }}
    secondaryCTA={{ label: "Read Blog", href: "/blog" }}
  />

  <!-- Professional Summary -->
  <section class="section-padding border-t border-surface-800/50">
    <div class="section-container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">
          Engineering Reliability at Scale
        </h2>
        <p class="text-surface-400 leading-relaxed text-lg">
          With over 8 years of experience in cloud engineering, I specialize in building 
          and operating distributed systems that handle millions of requests. From designing 
          multi-cloud architectures to implementing GitOps pipelines, I focus on automation, 
          observability, and developer experience.
        </p>
      </div>
    </div>
  </section>

  <!-- Technologies -->
  <section class="section-padding border-t border-surface-800/50">
    <div class="section-container">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-white">Technologies & Tools</h2>
        <p class="mt-3 text-surface-400">Core technologies I work with daily</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
        {technologies.map((tech) => (
          <TechBadge name={tech.name} icon={tech.icon} />
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section-padding border-t border-surface-800/50">
    <div class="section-container">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-white">Featured Projects</h2>
          <p class="mt-2 text-surface-400">Recent infrastructure and platform engineering work</p>
        </div>
        <a href="/projects" class="hidden sm:flex items-center gap-1 text-sm text-primary-400 hover:text-primary-300 transition-colors">
          View all
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            technologies={project.technologies.slice(0, 4)}
            href={`/projects/${project.slug}`}
            github={project.github}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  <section class="section-padding border-t border-surface-800/50">
    <div class="section-container">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-white">Latest Articles</h2>
          <p class="mt-2 text-surface-400">Thoughts on cloud engineering and DevOps</p>
        </div>
        <a href="/blog" class="hidden sm:flex items-center gap-1 text-sm text-primary-400 hover:text-primary-300 transition-colors">
          View all
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {blogPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.publishedDate}
            category={post.data.category}
            readingTime={`${Math.ceil(post.body!.split(/\s+/).length / 200)} min read`}
            href={`/blog/${post.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications Preview -->
  <section class="section-padding border-t border-surface-800/50">
    <div class="section-container">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-white">Certifications</h2>
          <p class="mt-2 text-surface-400">Professional cloud and infrastructure certifications</p>
        </div>
        <a href="/certifications" class="hidden sm:flex items-center gap-1 text-sm text-primary-400 hover:text-primary-300 transition-colors">
          View all
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featuredCerts.map((cert) => (
          <CertificationCard
            title={cert.title}
            issuer={cert.issuer}
            date={cert.date}
            credentialUrl={cert.credentialUrl}
            description={cert.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    title="Let's Build Something Together"
    description="Interested in working together or discussing cloud architecture? I'd love to connect."
    primaryCTA={{ label: "Get in Touch", href: "/contact" }}
    secondaryCTA={{ label: "View Resume", href: "/resume" }}
  />
</BaseLayout>
