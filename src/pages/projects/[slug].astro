---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import TechBadge from "@components/TechBadge.astro";
import { projects } from "@/data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={project.title} description={project.description}>
  <section class="section-padding">
    <div class="section-container">
      <div class="max-w-4xl mx-auto">
        <Breadcrumbs
          items={[
            { label: "Home", href: "/" },
            { label: "Projects", href: "/projects" },
            { label: project.title },
          ]}
        />

        <!-- Header -->
        <header class="mt-8 mb-12">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white tracking-tight">
            {project.title}
          </h1>
          <p class="mt-4 text-lg text-surface-400 leading-relaxed">
            {project.description}
          </p>

          <div class="flex flex-wrap gap-3 mt-6">
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">
                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                View Source
              </a>
            )}
            {project.demo && (
              <a href={project.demo} target="_blank" rel="noopener noreferrer" class="btn-primary text-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Live Demo
              </a>
            )}
          </div>
        </header>

        <!-- Project Image -->
        <div class="mb-12 rounded-xl border border-surface-800 overflow-hidden bg-surface-900/50 p-8 flex items-center justify-center min-h-[300px]">
          <div class="text-center">
            <svg class="w-16 h-16 text-surface-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-surface-500 text-sm">Architecture diagram placeholder</p>
          </div>
        </div>

        <!-- Description -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4">Overview</h2>
          <p class="text-surface-300 leading-relaxed">{project.longDescription}</p>
        </div>

        <!-- Tech Stack -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4">Technology Stack</h2>
          <div class="flex flex-wrap gap-2">
            {project.technologies.map((tech) => (
              <TechBadge name={tech} />
            ))}
          </div>
        </div>

        <!-- Lessons Learned -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4">Lessons Learned</h2>
          <ul class="space-y-3">
            {project.lessons.map((lesson) => (
              <li class="flex items-start gap-3 text-surface-300">
                <svg class="w-5 h-5 text-primary-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
                {lesson}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
