---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="section-padding min-h-[60vh] flex items-center">
    <div class="section-container text-center">
      <p class="text-8xl font-bold gradient-text mb-4">404</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-4">Page Not Found</h1>
      <p class="text-surface-400 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="/" class="btn-primary">
          Go Home
        </a>
        <a href="/blog" class="btn-secondary">
          Read Blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
