# Site Configuration
PUBLIC_SITE_URL=https://your-domain.pages.dev

# Cloudflare Turnstile (for contact form)
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Contact Form (optional: use a service like Formspree or Cloudflare Workers)
PUBLIC_CONTACT_FORM_ENDPOINT=https://formspree.io/f/your-form-id
